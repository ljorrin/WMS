# ─── WMS Panama — .gitignore ──────────────────────────────────────────────────

# Entorno
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Logs
*.log
logs/

# Docker
*.override.yml

# Alembic (versiones sí se suben, pero no datos)
# alembic/versions/*.pyc  ← ya cubierto por __pycache__

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Secrets y certificados
*.p12
*.pem
*.key
*.crt
secrets/

# Archivos de datos temporales
*.csv
*.xlsx
*.json
!package.json
