# ─── WMS Panama — Variables de Entorno ─────────────────────────────────────────
# Copia este archivo como .env y completa los valores.
# NUNCA subas .env a git — está en .gitignore.
# Generar SECRET_KEY: openssl rand -hex 32
# ──────────────────────────────────────────────────────────────────────────────

# ── Identidad ─────────────────────────────────────────────────────────────────
APP_NAME="WMS Panama"
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ── Seguridad (OBLIGATORIO) ────────────────────────────────────────────────────
SECRET_KEY=GENERA_CON_openssl_rand_hex_32_MINIMO_32_CHARS

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL 16 ─────────────────────────────────────────────────────────────
POSTGRES_USER=wms_user
POSTGRES_PASSWORD=wms_secret
POSTGRES_DB=wms_db
DATABASE_URL=postgresql+asyncpg://wms_user:wms_secret@localhost:5432/wms_db
DATABASE_SYNC_URL=postgresql+psycopg2://wms_user:wms_secret@localhost:5432/wms_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false

# ── Redis 7 ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2

# ── Meilisearch ───────────────────────────────────────────────────────────────
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=meili_master_dev

# ── SMTP (desarrollo: MailHog en localhost:1025 / localhost:8025) ─────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_TLS=false
EMAIL_FROM=noreply@wmspanama.com
EMAIL_FROM_NAME="WMS Panama"

# ── Keycloak SSO (opcional) ────────────────────────────────────────────────────
KEYCLOAK_ENABLED=false
# KEYCLOAK_SERVER_URL=http://localhost:8080
# KEYCLOAK_REALM=wms-panama
# KEYCLOAK_CLIENT_ID=wms-backend
# KEYCLOAK_CLIENT_SECRET=CHANGE_ME

# ── AI / ML (opcional) ────────────────────────────────────────────────────────
AI_ENABLED=false
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── Storage S3/MinIO (opcional) ────────────────────────────────────────────────
# S3_ENDPOINT_URL=http://localhost:9000   ← MinIO
# S3_ACCESS_KEY=CHANGE_ME
# S3_SECRET_KEY=CHANGE_ME
# S3_BUCKET_NAME=wms-files
# S3_REGION=us-east-1

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Panama — APIs Regulatorias ────────────────────────────────────────────────
# ANA_SIGA_API_KEY=CHANGE_ME
# DGI_RUC=CHANGE_ME
# DGI_CERTIFICATE_PATH=/secrets/dgi_cert.p12

# ── Observabilidad ─────────────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Superadmin inicial (para seed) ────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@wmspanama.com
SUPERADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN8
